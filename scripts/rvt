#!/bin/bash

# Converts Revolut extension JSON export to Actual Budget CSV format.
# Usage: rvt <input.json>
# Pipe into jsontocsv for final CSV output.

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: $0 <revolut-export.json>" >&2
  exit 1
fi

input="$1"

if [ ! -f "$input" ]; then
  echo "File not found: $input" >&2
  exit 1
fi

jq '[
  .[]
  | select(.state != "DECLINED")
  | select(.type != "TRANSFER")
  | {
      date: (.startedDate / 1000 | strftime("%Y-%m-%d")),
      amount: (.amount / 100),
      payee: (.merchant.name // .description),
      imported_payee: .description,
      imported_id: .id,
      cleared: (.state == "COMPLETED"),
      notes: ([.card.lastFour, .description] | map(select(. != null and . != "")) | join(" | "))
    }
]' "$input"
