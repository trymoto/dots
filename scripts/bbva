#!/bin/bash

# Converts BBVA JSON export to Actual Budget CSV format.
# Usage: bbva <input.json>
# Pipe into jsontocsv for final CSV output.

set -euo pipefail

if [ $# -lt 1 ]; then
  echo "Usage: $0 <bbva-export.json>" >&2
  exit 1
fi

input="$1"

if [ ! -f "$input" ]; then
  echo "File not found: $input" >&2
  exit 1
fi

jq '[
  (if type == "object" then .data else . end)[]
  | {
      date: (.operationDate | split("T")[0]),
      amount: (.operationAmounts[0].amount | if type == "object" then .parsedValue else . end),
      payee: (if (.transactionType.id | test("TRANSFER")) then .conceptDetail else .extendedConcept end),
      imported_payee: .conceptDetail,
      imported_id: .id,
      cleared: (.status.id == "SETTLED"),
      notes: ([.rmsCategory.subcategory.name, .additionalInformation.additionalData] | map(select(. != null and . != "")) | join(" | "))
    }
]' "$input"
